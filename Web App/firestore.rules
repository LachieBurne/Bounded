rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Secure the Users Collection
    match /users/{userId} {
      
      // A user can only read and write data mapped directly to their own UID
      allow read, write: if isOwner(userId);
      
      // Secure nested Binders collection
      match /binders/{binderId} {
        allow read, write: if isOwner(userId);
        
        // Secure specific Card Entries inside the Binder
        match /entries/{cardId} {
           allow read, write: if isOwner(userId);
        }
      }

      // Secure nested Decks collection
      match /decks/{deckId} {
        allow read, write: if isOwner(userId);
        
        // Secure specific Card Entries inside the Deck
        match /entries/{cardId} {
           allow read, write: if isOwner(userId);
        }
      }
    }
    
    // Default Deny Rule for any unspecified loose paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
